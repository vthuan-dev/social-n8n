# ===== Database =====
POSTGRES_USER=social
POSTGRES_PASSWORD=social_secret
POSTGRES_DB=social_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== Backend =====
BACKEND_PORT=4000
# URL công khai của backend (dùng làm redirect_uri OAuth Facebook)
BACKEND_PUBLIC_URL=http://localhost:4000
JWT_SECRET=change_this_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
# Khoá mã hoá token mạng xã hội (AES-256, 32 ký tự)
CREDENTIAL_ENCRYPTION_KEY=change_this_32_char_encryption_k
# URL n8n để backend gọi trigger
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_GENERATE=http://n8n:5678/webhook/generate-content
N8N_WEBHOOK_PUBLISH=http://n8n:5678/webhook/publish-content
# Secret xác thực webhook giữa backend <-> n8n
WEBHOOK_SECRET=change_this_webhook_secret

# ===== Frontend =====
FRONTEND_PORT=3000
# URL dashboard để backend redirect về sau OAuth + whitelist CORS
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ===== AI =====
# Groq (OpenAI-compatible, free tier) — lấy key tại https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# Pollinations.ai không cần key (miễn phí)
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# ===== Facebook =====
FACEBOOK_APP_ID=your_fb_app_id
FACEBOOK_APP_SECRET=your_fb_app_secret

# ===== n8n =====
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh
